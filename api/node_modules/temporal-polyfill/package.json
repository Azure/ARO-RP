{
  "name": "temporal-polyfill",
  "version": "0.3.2",
  "title": "Temporal Polyfill",
  "description": "A lightweight polyfill for Temporal, successor to the JavaScript Date object",
  "author": {
    "name": "Adam Shaw",
    "email": "arshaw@users.noreply.github.com",
    "url": "http://arshaw.com/"
  },
  "contributors": [
    {
      "name": "Ishaan Bharal",
      "email": "ishbharal@gmail.com"
    }
  ],
  "license": "MIT",
  "copyright": "2024 Adam Shaw",
  "repository": {
    "type": "git",
    "url": "https://github.com/fullcalendar/temporal-polyfill.git"
  },
  "type": "module",
  "dependencies": {
    "temporal-spec": "0.3.1"
  },
  "main": "./index.cjs",
  "types": "./index.d.ts",
  "module": "./index.js",
  "exports": {
    ".": {
      "module-sync": "./index.js",
      "require": "./index.cjs",
      "import": "./index.js"
    },
    "./impl": {
      "module-sync": "./impl.js",
      "require": "./impl.cjs",
      "import": "./impl.js"
    },
    "./global": {
      "module-sync": "./global.esm.js",
      "require": "./global.cjs",
      "import": {
        "types": "./global.d.ts",
        "default": "./global.esm.js"
      }
    },
    "./fns/instant": {
      "module-sync": "./fns/instant.js",
      "require": "./fns/instant.cjs",
      "import": "./fns/instant.js"
    },
    "./fns/zoneddatetime": {
      "module-sync": "./fns/zoneddatetime.js",
      "require": "./fns/zoneddatetime.cjs",
      "import": "./fns/zoneddatetime.js"
    },
    "./fns/plaindatetime": {
      "module-sync": "./fns/plaindatetime.js",
      "require": "./fns/plaindatetime.cjs",
      "import": "./fns/plaindatetime.js"
    },
    "./fns/plaindate": {
      "module-sync": "./fns/plaindate.js",
      "require": "./fns/plaindate.cjs",
      "import": "./fns/plaindate.js"
    },
    "./fns/plaintime": {
      "module-sync": "./fns/plaintime.js",
      "require": "./fns/plaintime.cjs",
      "import": "./fns/plaintime.js"
    },
    "./fns/plainyearmonth": {
      "module-sync": "./fns/plainyearmonth.js",
      "require": "./fns/plainyearmonth.cjs",
      "import": "./fns/plainyearmonth.js"
    },
    "./fns/plainmonthday": {
      "module-sync": "./fns/plainmonthday.js",
      "require": "./fns/plainmonthday.cjs",
      "import": "./fns/plainmonthday.js"
    },
    "./fns/duration": {
      "module-sync": "./fns/duration.js",
      "require": "./fns/duration.cjs",
      "import": "./fns/duration.js"
    },
    "./fns/now": {
      "module-sync": "./fns/now.js",
      "require": "./fns/now.cjs",
      "import": "./fns/now.js"
    }
  },
  "jsdelivr": "./global.min.js",
  "unpkg": "./global.min.js",
  "sideEffects": [
    "./global.cjs",
    "./global.esm.js",
    "./global.js",
    "./global.min.js"
  ]
}