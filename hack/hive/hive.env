# shellcheck shell=bash
# shellcheck disable=SC2034

# declare -r __hive_env_sourced="true"
declare -r __hive_env_sourced="true"

# declare -r HIVE_OPERATOR_NS="hive"
declare -r HIVE_OPERATOR_NS="hive"

# declare -r HIVE_DEPLOYMENT_OPERATOR="hive-operator"
declare -r HIVE_DEPLOYMENT_OPERATOR="deployment/hive-operator"

# declare -r HIVE_DEPLOYMENT_CONTROLLERS="deployment/hive-controllers"
declare -r HIVE_DEPLOYMENT_CONTROLLERS="deployment/hive-controllers"

# declare -r HIVE_GLOBAL_PULL_SECRET_NAME="hive-global-pull-secret"
declare -r HIVE_GLOBAL_PULL_SECRET_NAME="hive-global-pull-secret"

# declare -r HIVE_CONFIG="hack/hive/hive-config"
declare -r HIVE_CONFIG="hack/hive/hive-config"
