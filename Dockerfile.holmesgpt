ARG BASE_REGISTRY=docker.io
ARG REPOSITORY=python
ARG TAG=3.11-slim-bookworm
FROM ${BASE_REGISTRY}/${REPOSITORY}:${TAG} AS builder
ARG HOLMESGPT_VERSION

USER root
WORKDIR /build

RUN apt-get update \
    && apt-get install -y build-essential curl git \
    && rm -rf /var/lib/apt/lists/*

RUN python -m venv /venv --upgrade-deps
ENV PATH="/venv/bin:$PATH"
RUN pip install --no-cache-dir holmesgpt==${HOLMESGPT_VERSION}

#### Runtime container
FROM ${BASE_REGISTRY}/${REPOSITORY}:${TAG}

USER root
WORKDIR /app

ENV PYTHONUNBUFFERED=1
ENV PATH="/venv/bin:$PATH"
ENV HOME=/tmp

COPY --from=builder /venv /venv

# Install kubectl
RUN apt-get update \
    && apt-get install -y curl jq gnupg2 apt-transport-https \
    && curl -fsSL https://pkgs.k8s.io/core:/stable:/v1.34/deb/Release.key \
       | gpg --dearmor -o /etc/apt/keyrings/kubernetes-apt-keyring.gpg \
    && echo 'deb [signed-by=/etc/apt/keyrings/kubernetes-apt-keyring.gpg] https://pkgs.k8s.io/core:/stable:/v1.34/deb/ /' \
       | tee /etc/apt/sources.list.d/kubernetes.list \
    && apt-get update && apt-get install -y kubectl \
    && rm -rf /var/lib/apt/lists/*

USER 1001
ENTRYPOINT ["holmes"]
